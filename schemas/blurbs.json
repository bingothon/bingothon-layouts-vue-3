{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "charity": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "text": {
                        "type": "string"
                    },
                    "enabled": {
                        "type": "boolean",
                        "default": true
                    }
                },
                "required": ["text", "enabled"],
                "additionalProperties": false
            },
            "default": []
        },
        "sponsor": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "text": {
                        "type": "string"
                    },
                    "enabled": {
                        "type": "boolean",
                        "default": true
                    }
                },
                "required": ["text", "enabled"],
                "additionalProperties": false
            },
            "default": []
        },
        "bingothon": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "text": {
                        "type": "string"
                    },
                    "enabled": {
                        "type": "boolean",
                        "default": true
                    }
                },
                "required": ["text", "enabled"],
                "additionalProperties": false
            },
            "default": []
        }
    },
    "required": ["charity", "sponsor", "bingothon"]
}
